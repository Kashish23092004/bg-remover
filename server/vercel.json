{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["**/*.js", "**/*.json", "**/*.mjs"],
        "maxLambdaSize": "15mb",
        "supportsResponseStreaming": true
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    },
    {
      "src": "/webhooks/(.*)",
      "dest": "/server.js",
      "methods": ["POST"]
    },
    {
      "src": "/health",
      "dest": "/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "/server.js",
      "methods": ["GET"]
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "**/*.js"
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}